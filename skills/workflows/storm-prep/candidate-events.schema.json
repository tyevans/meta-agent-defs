{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "storm-prep-candidates.schema.json",
  "title": "Storm-Prep Candidate Events",
  "description": "Schema for YAML files generated by /storm-prep (Phase 1 of Event Storming). Consumed by human jam sessions and /formalize.",
  "type": "object",
  "required": ["metadata", "domain_events", "boundary_assumptions"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["role", "scope", "goal", "generated_at", "event_count", "assumption_count"],
      "additionalProperties": false,
      "properties": {
        "role": {
          "type": "string",
          "description": "The domain role or perspective that generated these candidates (e.g. 'session-orchestration')."
        },
        "scope": {
          "type": "string",
          "description": "Human-readable description of the domain scope covered."
        },
        "goal": {
          "type": "string",
          "description": "The project goal driving this event discovery."
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of generation."
        },
        "event_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of domain events in this file."
        },
        "assumption_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of boundary assumptions in this file."
        }
      }
    },
    "domain_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/domain_event" }
    },
    "boundary_assumptions": {
      "type": "array",
      "items": { "$ref": "#/$defs/boundary_assumption" }
    }
  },
  "$defs": {
    "domain_event": {
      "type": "object",
      "required": ["name", "aggregate", "trigger", "payload", "integration", "confidence"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9]+$",
          "description": "PascalCase event name (e.g. 'SandboxCreated')."
        },
        "aggregate": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9]+$",
          "description": "PascalCase aggregate that owns this event."
        },
        "trigger": {
          "type": "string",
          "description": "What causes this event (command, external signal, etc.)."
        },
        "payload": {
          "type": "array",
          "items": { "$ref": "#/$defs/payload_field" },
          "description": "Event payload fields. Empty array for events with no data beyond aggregate ID."
        },
        "state_change": {
          "type": "string",
          "description": "State transition expressed as 'FROM -> TO' (e.g. 'CREATED -> STARTED')."
        },
        "integration": { "$ref": "#/$defs/integration" },
        "sources": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "Source file reference in 'path/to/file:line-line' format."
          },
          "description": "Codebase locations that evidence this event. May be empty for proposed events."
        },
        "confidence": { "$ref": "#/$defs/confidence" },
        "notes": {
          "type": "string",
          "description": "Optional free-text notes, caveats, or context."
        }
      }
    },
    "payload_field": {
      "type": "object",
      "required": ["field", "type"],
      "additionalProperties": false,
      "properties": {
        "field": {
          "type": "string",
          "description": "Field name (snake_case)."
        },
        "type": {
          "type": "string",
          "description": "Python type annotation (e.g. 'str', 'int', 'list[dict]', 'str | None')."
        }
      }
    },
    "integration": {
      "type": "object",
      "required": ["direction"],
      "additionalProperties": false,
      "properties": {
        "direction": {
          "type": "string",
          "enum": ["inbound", "outbound", "internal"],
          "description": "Whether this event crosses BC boundaries and in which direction."
        },
        "channel": {
          "type": "string",
          "description": "How the event is propagated (e.g. 'event store', 'direct method call')."
        }
      }
    },
    "boundary_assumption": {
      "type": "object",
      "required": ["id", "type", "statement", "affects_events", "confidence", "verify_with"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^BA-\\d+$",
          "description": "Assumption identifier (e.g. 'BA-1')."
        },
        "type": {
          "type": "string",
          "enum": ["ownership", "contract", "ordering", "existence"],
          "description": "Category of assumption."
        },
        "statement": {
          "type": "string",
          "description": "The assumption being made."
        },
        "affects_events": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Event names affected by this assumption."
        },
        "confidence": { "$ref": "#/$defs/confidence" },
        "verify_with": {
          "type": "string",
          "description": "How to validate this assumption (team discussion, spike, etc.)."
        }
      }
    },
    "confidence": {
      "type": "string",
      "enum": ["CONFIRMED", "LIKELY", "POSSIBLE"],
      "description": "Confidence level: CONFIRMED (in codebase), LIKELY (strong evidence), POSSIBLE (proposed/speculative)."
    }
  }
}
